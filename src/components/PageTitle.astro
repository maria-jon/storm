---
const { title, color } = Astro.props;
---

<h1 class=`${color} page-title`>
    {title}
</h1>

<style>
    .text-peachy-pink {
        color: var(--peachy-pink);
    }

    .text-wine-red {
        color: var(--wine-red);
    }

    h1 {
        font-size: clamp(3em, 10vw, 6em);
        white-space: nowrap;
    }
</style>